{
  "name": "proof-sdk",
  "version": "0.1.0",
  "description": "Open-source collaborative markdown editor with provenance tracking and an agent HTTP bridge",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/finalize-web-build.mjs",
    "cf:init": "node scripts/cf-init.mjs",
    "dev:worker": "wrangler dev",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "test": "npm run test:proof-sdk && npm run test:worker-access",
    "test:worker-access": "tsx src/tests/worker-access-identity.test.ts",
    "test:conformance": "tsx src/tests/worker-conformance.test.ts",
    "test:collab-sync": "tsx src/tests/worker-collab-sync.test.ts",
    "test:durability": "tsx src/tests/worker-durability.test.ts",
    "test:human-identity": "tsx src/tests/worker-human-identity.test.ts",
    "test:agent-ops": "tsx src/tests/worker-agent-ops.test.ts",
    "test:share-lifecycle": "tsx src/tests/worker-share-lifecycle.test.ts",
    "test:r2-snapshots": "tsx src/tests/worker-r2-snapshots.test.ts",
    "test:library": "tsx src/tests/worker-library.test.ts",
    "test:proof-sdk": "tsx src/tests/proof-sdk-agent-bridge-client.test.ts",
    "demo:agent": "npm --workspace proof-example run demo:agent",
    "test:bug-reports": "tsx src/tests/worker-bug-reports.test.ts"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@handlewithcare/prosemirror-suggest-changes": "^0.1.8",
    "@milkdown/core": "^7.5.0",
    "@milkdown/kit": "^7.5.0",
    "@milkdown/plugin-clipboard": "^7.5.0",
    "@milkdown/plugin-collab": "^7.18.0",
    "@milkdown/plugin-cursor": "^7.5.0",
    "@milkdown/plugin-history": "^7.5.0",
    "@milkdown/plugin-listener": "^7.5.0",
    "@milkdown/plugin-prism": "^7.18.0",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/theme-nord": "^7.5.0",
    "beautiful-mermaid": "^1.1.3",
    "jose": "^6.2.3",
    "partyserver": "^0.5.8",
    "prismjs": "^1.30.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "web-haptics": "^0.0.6",
    "ws": "^8.19.0",
    "y-partyserver": "^2.2.0",
    "y-prosemirror": "^1.2.19",
    "yjs": "^13.6.20",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/node": "^20.10.0",
    "@types/prismjs": "^1.26.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^8.1.3",
    "wrangler": "^4.107.0"
  }
}
