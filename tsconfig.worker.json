{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["workers/**/*.ts"],
  // The headless engine belongs to the upstream-stable editor surface and
  // does not pass the strict worker program; the headless-engine.js/.d.ts
  // shim is the type boundary (see that file). Bundling follows the import.
  "exclude": ["workers/milkdown-headless.ts"]
}
